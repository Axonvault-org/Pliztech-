{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000",
        "EXPO_PUBLIC_KYC_REQUIRE_FACE_LIVENESS": "false"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "EXPO_PUBLIC_KYC_REQUIRE_FACE_LIVENESS": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.plz.ng",
        "EXPO_PUBLIC_KYC_REQUIRE_FACE_LIVENESS": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
