{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.plz.ng",
        "EXPO_PUBLIC_FRONTEND_URL": "https://app-staging.plz.ng"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.plz.ng",
        "EXPO_PUBLIC_FRONTEND_URL": "https://app.plz.ng"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6774841857"
      }
    }
  }
}