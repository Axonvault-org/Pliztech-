# Plz mobile app — copy to `.env` and restart Expo after changes.
# Production values are set in EAS secrets / build profiles.

# Backend API (no trailing slash)
# - iOS Simulator / web: http://localhost:3000
# - Android emulator: same — app maps localhost → 10.0.2.2 automatically
# - Physical phone on Wi‑Fi: http://YOUR_MAC_LAN_IP:3000 (backend must be running)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Web app origin for Paystack mobile checkout redirect (must match backend FRONTEND_URL)
EXPO_PUBLIC_FRONTEND_URL=http://localhost:8081

# Google Sign-In (Web client ID from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
